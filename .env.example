# Copy to .env and fill in only the keys for providers you actually use.
# The default pipeline (BGE embeddings + Groq LLM) needs only GROQ_API_KEY.

# --- LLM providers (answer + judge) ---
# Default provider. Free tier available at https://console.groq.com/keys
GROQ_API_KEY=

# Optional LLM providers (opt-in via config: llm.provider = openai | anthropic)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Embedding providers ---
# Default embeddings are local BGE and need NO key.
# Optional embedding providers (opt-in via config: embedding.provider = openai | voyage)
# OPENAI_API_KEY is shared with the LLM provider above.
VOYAGE_API_KEY=
